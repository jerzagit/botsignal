# ═══════════════════════════════════════════════════════
#  SignalBot — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER share your .env file with anyone.
# ═══════════════════════════════════════════════════════

# ── Telegram User Account ─────────────────────────────
#  Get from: https://my.telegram.org → API development tools
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# ── Your Personal Bot ─────────────────────────────────
#  Create via @BotFather on Telegram
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Your Telegram Chat ID ─────────────────────────────
#  Send any message to @userinfobot to get this
YOUR_CHAT_ID=987654321

# ── Mentor's Signal Group ─────────────────────────────
#  Username (without @) OR numeric group ID
#  You must be a member of this group already
SIGNAL_GROUP=AssistByHafizCarat

# ── MT5 Account ───────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=YourMT5PasswordHere
MT5_SERVER=YourBroker-Server

# ── Risk Management ───────────────────────────────────
#  % of FREE MARGIN to risk per trade
#  0.05 = 5% | 0.10 = 10%
#  Bot auto-calculates lot size based on SL distance + this %
RISK_PERCENT=0.05

#  Safety guardrails — lot will never go outside these bounds
MIN_LOT=0.01
MAX_LOT=0.50

#  Seconds before a pending confirmation expires (default: 5 min)
SIGNAL_EXPIRY=300

# ── Night Trading Agent ───────────────────────────────
#  Active window in MALAYSIA TIME (UTC+8)
#  Default: 10 PM → 6 AM (covers London open + NY session)
AGENT_START_HOUR_MY=22
AGENT_END_HOUR_MY=6

#  Auto-execute during agent hours? (true/false)
#  true  = agent places trades automatically while you sleep
#  false = agent still sends you confirmation buttons (safer)
#  ⚠️  Set to true only after you trust the system fully!
AGENT_AUTO_EXECUTE=false

#  Enable agent when running bot.py? (true/false)
AGENT_ENABLED=true
